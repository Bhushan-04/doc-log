{
  "name": "doc-log-cli",
  "version": "0.1.1",
  "description": "A CLI that uses the Cursor agent (via CURSOR_API_KEY) to generate and maintain Doc-Log documentation for a codebase.",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Bhushan-04/doc-log.git"
  },
  "homepage": "https://github.com/Bhushan-04/doc-log#readme",
  "bugs": "https://github.com/Bhushan-04/doc-log/issues",
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "bin": {
    "doc-log": "./dist/cli.js"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "keywords": [
    "ai",
    "agents",
    "documentation",
    "wiki",
    "cursor",
    "cli"
  ],
  "scripts": {
    "doc-log": "node dist/cli.js",
    "build": "tsc -p tsconfig.json",
    "clean": "node -e \"require('node:fs').rmSync('dist',{recursive:true,force:true})\"",
    "dev": "tsx src/cli.tsx",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "lint": "eslint . --fix",
    "lint:check": "eslint .",
    "prebuild": "pnpm run clean",
    "prepack": "pnpm run build",
    "prepublishOnly": "pnpm run lint:check && pnpm run format:check",
    "start": "node dist/cli.js"
  },
  "dependencies": {
    "@cursor/sdk": "^1.0.22",
    "ink": "^5.1.0",
    "marked": "^18.0.5",
    "react": "^18.3.1"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^22.10.2",
    "@types/react": "^18.3.17",
    "eslint": "^10.5.0",
    "prettier": "^3.8.4",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "typescript-eslint": "^8.62.0"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild"
    ]
  },
  "packageManager": "pnpm@10.33.2+sha512.a90faf6feeab71ad6c6e57f94e0fe1a12f5dcc22cd754db40ae9593eb6a3e0b6b12e3540218bb37ae083404b1f2ce6db2a4121e979829b4aff94b99f49da1cf8"
}
